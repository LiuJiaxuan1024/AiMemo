APP_ENV=development
DATABASE_URL=sqlite:///./data/ai_note.db
LANGGRAPH_CHECKPOINT_PATH=./data/langgraph_checkpoints.db
JOB_WORKER_ENABLED=true
JOB_WORKER_POLL_INTERVAL_SECONDS=2
JOB_RUNNING_TIMEOUT_SECONDS=600

DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=
EMBEDDING_MODEL=

# Local Operator read-only 默认允许仓库根目录和当前用户 Home。
# 如需追加更多可读取目录，用分号或逗号分隔。
# 示例：LOCAL_OPERATOR_WORKSPACE_ROOTS=E:\Ai记;D:\资料;~/Documents
LOCAL_OPERATOR_WORKSPACE_ROOTS=

# Ai 记本地开发默认关闭 LangSmith tracing。
# 如果确实要上传 LangGraph/LangChain trace，再显式设置为 true。
AIJI_ENABLE_LANGSMITH_TRACING=false

# 浏览器内主精灵默认关闭；桌面 Memo Elf 会从后端订阅精灵事件。
# 如果只想在 Web 页面中调试精灵，可以设置为 true。
VITE_ENABLE_WEB_ELF=false
